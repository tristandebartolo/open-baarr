<?php

use Drupal\taxonomy\Entity\Term;

/**
 * Implements hook_preprocess_HOOK() for html.html.twig.
 */
function gentil_claro_preprocess_html(array &$variables) {

  if ($node = \Drupal::request()->attributes->get('node')) {
    $content_type = $node->bundle();
    $variables['attributes']['class'][] = 'page-' . $node->id();
    $variables['attributes']['class'][] = 'page-' . str_replace('.','-', $content_type);
    // if ($node->bundle() == 'poeme' && $node->hasField('field_type_poeme')) {
    //   $type_poeme = $node->field_type_poeme->getValue()[0]['value'];
    //   if ($type_poeme) {
    //     $variables['attributes']['class'][] = 'page-' . $type_poeme . '-poeme';
    //   }
    // }
  }

  $current_path = \Drupal::service('path.current')->getPath();
  $is_front = \Drupal::service('path.matcher')->isFrontPage();

  // $cp = \Drupal::service('path.alias_manager');
  $host = \Drupal::request()->getSchemeAndHttpHost();

  if ($host) {
    $variables['#attached']['drupalSettings']['tdb_timeline_host'] = $host;
  }

  if ($current_path ) {
    // $variables['current_path'] = $cp->getAliasByPath($current_path);
    $variables['#attached']['drupalSettings']['tdb_timeline_current_route'] = $current_path;
    $variables['#attached']['drupalSettings']['tdb_timeline_current_front'] = $is_front;
    // $variables['#attached']['drupalSettings']['tdb_timeline_route'] = \Drupal::service('path.alias_manager')->getAliasByPath($current_path);
  }

  // if (\Drupal::routeMatch()->getRouteName() == 'entity.taxonomy_term.canonical') {
  //   $tid = \Drupal::routeMatch()->getRawParameter('taxonomy_term');
  //   $term = Term::load($tid);

  //   $variables['term_id'] = $tid;
  // }

  // if ($term = \Drupal::routeMatch()->getParameter('taxonomy_term')) {
  //   $tid = $term->id();
  //   $bundle = $term->bundle();
  //   if ($bundle === 'figures') {
  //     $variables['#attached']['drupalSettings']['tdb_timeline_route'] = 'base-route-' . $bundle;
  //   }
  //   $variables['term_id'] = $tid;
  // }elseif (\Drupal::service('path.matcher')->isFrontPage() === TRUE) {
  //   $variables['#attached']['drupalSettings']['tdb_timeline_route'] = 'base-route-front';
  // }else{
  //   $variables['#attached']['drupalSettings']['tdb_timeline_route'] = NULL;
  // }

}

/**
 * Implements hook_preprocess_page() for page.html.twig.
 */
function gentil_claro_preprocess_page(array &$variables) {

  $user = \Drupal::currentUser();
  $isAnonymous = $user->isAnonymous() ? false : true;

  $variables['#attached']['drupalSettings']['tdb_timeline'] = NULL;
  $variables['logged_in'] = $isAnonymous;
  if ($isAnonymous) {
    $variables['user_id'] = $user->id();
  }
  if ($node = \Drupal::routeMatch()->getParameter('node')) {
    $variables['Tnid'] = $node->id();
  }
  if ($term = \Drupal::routeMatch()->getParameter('taxonomy_term')) {
    // dsm($term);
    // $variables['Ttid'] = $term->id();
    // $variables['#attached']['drupalSettings']['tdb_timeline'] = ['id' => $term->id(), 'label' => $term->label()];
  }
}

/**
 * Implements hook_theme_suggestions_node_alter().
 */
function gentil_claro_theme_suggestions_taxonomy_term_alter(array &$suggestions, array $variables) {
  // Add custom template for element menu local task page user
  $elements = $variables['elements'];
  if($elements && $elements['#view_mode']) {
    $sanitized_view_mode = strtr($elements['#view_mode'], ' ', '_');
    $suggestions[] = 'taxonomy_term__' .$sanitized_view_mode;
    if($elements && $elements['name']) {
      $sanitized_bundle = strtr($elements['name']['#bundle'], ' ', '_');
      $suggestions[] = 'taxonomy_term__' .$sanitized_bundle;
      $suggestions[] = 'taxonomy_term__' .$sanitized_bundle. '_' .$sanitized_view_mode;
    }
  }
}

