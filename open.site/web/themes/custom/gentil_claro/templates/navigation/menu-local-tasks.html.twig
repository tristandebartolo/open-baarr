{#
/**
 * @file
 * Claro theme implementation to display primary and secondary local tasks.
 *
 * Available variables:
 * - primary: HTML list items representing primary tasks.
 * - secondary: HTML list items representing secondary tasks.
 *
 * Each item in these variables (primary and secondary) can be individually
 * themed in menu-local-task.html.twig.
 *
 * @ingroup themeable
 */
#}
{% if primary %}
  <h2 id="cc-tabs-primary-title" class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
  <nav role="navigation" class="cc-tabs-nav" aria-labelledby="cc-tabs-primary-title">
    <ul class="cc-tabs-wrapper cc-tabs-wrapper-primary clearfix cc-tabs-horizontal">{{ primary }}</ul>
  </nav>
{% endif %}
{% if secondary %}
   <h2 id="cc-tabs-secondary-title" class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
  <nav role="navigation" class="cc-tabs-nav" aria-labelledby="cc-tabs-secondary-title">
    <ul class="cc-tabs-wrapper cc-tabs-wrapper-secondary clearfix cc-tabs-horizontal">{{ secondary }}</ul>
  </nav>
{% endif %}
