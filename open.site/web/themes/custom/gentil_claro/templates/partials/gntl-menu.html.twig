{#
/**
 * @file
 * Navbar du site — mobile-first.
 *
 * Logo à gauche, menu principal inline dès 960px (uk-visible@m), à droite :
 * bascule dark/light + burger mobile ouvrant l'offcanvas UIkit. Le menu de
 * l'offcanvas est cloné depuis le menu desktop par js/gntl-offcanvas.js
 * (page.menu ne doit être rendu qu'une fois : un second print serait vide).
 */
#}
<div class="gntl-nav uk-section uk-padding-remove-vertical" uk-sticky="end: !.page-wrapper;">
	<div class="gntl-nav-container uk-container">
		<div class="gntl-nav-wrapper">

			<div class="gntl-nav-branding">
				<div class="gntl-branding-logo">
					<a href="/">
						{% include directory ~ '/templates/partials/gntl-logo.html.twig' %}
						<span class="visually-hidden">{{'Accueil'}}</span>
					</a>
				</div>
				{% if page.branding %}
					<div class="gntl-branding-name">
						{{ page.branding }}
					</div>
				{% endif %}
			</div>

			<nav class="gntl-navbar-menu uk-visible@m" aria-label="{{ 'Navigation principale'|t }}">
				{{ page.menu }}
			</nav>

			<div class="gntl-nav-actions">
				{% if tabs_node %}
					<div class="gntl-navbar-tabs uk-inline uk-animation-toggle">
						<button aria-expanded="false" data-ariacontrols="gm-trgt-page" class="oo-tabs" data-menus="tabs" type="button">
							<span class="i-gntl i-gntl--settings"></span>
						</button>
						<ul id="gm-trgt-page" class="oo-tabs-items">{{ tabs_node }}</ul>
					</div>
					{{ attach_library('gentil_front/menu-tabs') }}
				{% endif %}
				{% if page.third_menu %}
					{{ page.third_menu }}
				{% endif %}
				<button type="button" class="oc-theme-toggle" data-oc-theme-toggle aria-label="{{ 'Passer au thème sombre'|t }}" aria-pressed="false">
					{# Lune affichée en clair, soleil en sombre (via CSS). #}
					<svg class="oc-theme-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
					<svg class="oc-theme-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
				</button>
				<button type="button" class="gntl-burger uk-hidden@m" uk-toggle="target: #gntl-offcanvas"
					aria-label="{{ 'Ouvrir le menu'|t }}" aria-controls="gntl-offcanvas" aria-expanded="false" data-gntl-burger>
					<span class="gntl-burger__bar" aria-hidden="true"></span>
					<span class="gntl-burger__bar" aria-hidden="true"></span>
					<span class="gntl-burger__bar" aria-hidden="true"></span>
				</button>
			</div>

		</div>
	</div>
	<div id="progress-w-bar">
		<div id="progress-bar"></div>
	</div>
</div>

{# Offcanvas mobile : menu cloné en JS + bascule de thème. UIkit le déplace
   dans <body> et gère overlay, Échap et focus. #}
<div id="gntl-offcanvas" uk-offcanvas="mode: slide; overlay: true; flip: true">
	<div class="uk-offcanvas-bar gntl-offcanvas-bar">
		<button class="uk-offcanvas-close" type="button" uk-close aria-label="{{ 'Fermer le menu'|t }}"></button>
		<nav class="gntl-offcanvas-menu" aria-label="{{ 'Navigation principale'|t }}" data-gntl-offcanvas-menu></nav>
		<div class="gntl-offcanvas-footer">
			<span class="gntl-offcanvas-footer__label">{{ 'Thème'|t }}</span>
			<button type="button" class="oc-theme-toggle" data-oc-theme-toggle aria-label="{{ 'Passer au thème sombre'|t }}" aria-pressed="false">
				<svg class="oc-theme-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				<svg class="oc-theme-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
			</button>
		</div>
	</div>
</div>
