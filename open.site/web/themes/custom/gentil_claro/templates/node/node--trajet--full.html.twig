{#
/**
 * @file
 * Page détail d'un trajet — design repris de l'app mobile.
 *
 * Structure : carte héro bord à bord (tracé Leaflet), feuille de contenu
 * chevauchante, tuiles de stats, graphiques, santé/météo, notes, galerie.
 *
 * Variables injectées par opencar_display_preprocess_node() :
 * - trajet_activity : { type, label, color }
 * - trajet_started_at : date formatée ou null
 * - trajet_stats : { stats: [], health: [], weather: [] } (tuiles)
 * - trajet_map : { id } ou null
 * - trajet_charts : { id, keys, labels, summary } ou null
 * - trajet_gallery : [{ url, thumb, alt, caption, copyright }]
 */
#}
{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'oc-trajet',
  ]
%}
<article{{ attributes.addClass(classes).setAttribute('style', '--oc-activity: ' ~ trajet_activity.color) }}>

	{# 1. Carte héro bord à bord (repli sur la vignette sans tracé). #}
	{% if trajet_map %}
		<div class="oc-hero-map">
			<div class="oc-hero-map__canvas" data-opencar-map="{{ trajet_map.id }}" role="region" aria-label="{{ 'Carte du trajet'|t }}"></div>
			<button type="button" class="oc-map-expand" aria-expanded="false" aria-label="{{ 'Agrandir la carte'|t }}">
				<span uk-icon="icon: expand" aria-hidden="true"></span>
			</button>
		</div>
	{% elseif content.field_vignette|render %}
		<div class="oc-hero-vignette">
			{{ content.field_vignette }}
		</div>
	{% endif %}

	{# 2. Feuille de contenu chevauchant la carte. #}
	<div class="oc-sheet">
		<div class="uk-container uk-container-small">

			<header class="oc-trajet-header">
				<span class="oc-activity-badge" aria-hidden="true">
					<span uk-icon="icon: location"></span>
				</span>
				<div class="oc-trajet-header__text">
					<h1{{ title_attributes.addClass('oc-trajet-title') }}>{{ label }}</h1>
					<p class="oc-trajet-meta">
						{{ trajet_activity.label }}{% if trajet_started_at %} · {{ trajet_started_at }}{% endif %}
					</p>
				</div>
			</header>

			{% if content.field_chapo|render %}
				<div class="oc-trajet-chapo uk-text-lead">{{ content.field_chapo }}</div>
			{% endif %}

			{# 3. Tuiles de stats : distance en héros puis grille 2 col (3 en desktop). #}
			{% if trajet_stats.stats %}
				<section class="oc-section" aria-label="{{ 'Statistiques du trajet'|t }}">
					{% for tile in trajet_stats.stats %}
						{% if tile.hero %}
							{% include '@gentil_claro/partials/trajet-stat-tile.html.twig' with { tile: tile } only %}
						{% endif %}
					{% endfor %}
					<div class="uk-grid-small uk-child-width-1-2 uk-child-width-1-3@m" uk-grid>
						{% for tile in trajet_stats.stats %}
							{% if not tile.hero %}
								<div>{% include '@gentil_claro/partials/trajet-stat-tile.html.twig' with { tile: tile } only %}</div>
							{% endif %}
						{% endfor %}
					</div>
				</section>
			{% endif %}

			{# 4. Graphiques vitesse / altitude / fréquence cardiaque. #}
			{% if trajet_charts %}
				<section class="oc-section" aria-label="{{ 'Graphiques du trajet'|t }}">
					{% for key in trajet_charts.keys %}
						<div class="oc-chart-card">
							<h2 class="oc-section-label">{{ trajet_charts.labels[key] }}</h2>
							<div class="oc-chart-card__canvas">
								<canvas data-opencar-chart="{{ key }}" data-opencar-node="{{ trajet_charts.id }}" role="img" aria-label="{{ trajet_charts.summary[key] }}"></canvas>
							</div>
						</div>
					{% endfor %}
				</section>
			{% endif %}

			{# 5. Santé et météo au départ (sections présentes seulement si données). #}
			{% if trajet_stats.health %}
				<section class="oc-section" aria-label="{{ 'Santé'|t }}">
					<h2 class="oc-section-label">{{ 'Santé'|t }}</h2>
					<div class="uk-grid-small uk-child-width-1-2 uk-child-width-1-4@m" uk-grid>
						{% for tile in trajet_stats.health %}
							<div>{% include '@gentil_claro/partials/trajet-stat-tile.html.twig' with { tile: tile } only %}</div>
						{% endfor %}
					</div>
				</section>
			{% endif %}

			{% if trajet_stats.weather %}
				<section class="oc-section" aria-label="{{ 'Météo au départ'|t }}">
					<h2 class="oc-section-label">{{ 'Météo au départ'|t }}</h2>
					<div class="uk-grid-small uk-child-width-1-2 uk-child-width-1-3@m" uk-grid>
						{% for tile in trajet_stats.weather %}
							<div>{% include '@gentil_claro/partials/trajet-stat-tile.html.twig' with { tile: tile } only %}</div>
						{% endfor %}
					</div>
				</section>
			{% endif %}

			{# 6. Description et thématiques. #}
			{% if content.field_body|render %}
				<section class="oc-section oc-trajet-body">
					{{ content.field_body }}
				</section>
			{% endif %}

			{% if content.field_thematiques|render %}
				<div class="oc-trajet-tags">{{ content.field_thematiques }}</div>
			{% endif %}

			{# 7. Galerie photos (lightbox UIkit). #}
			{% if trajet_gallery %}
				<section class="oc-section oc-gallery" aria-label="{{ 'Galerie'|t }}">
					<h2 class="oc-section-label">{{ 'Galerie'|t }}</h2>
					<div class="uk-grid-small uk-child-width-1-2 uk-child-width-1-3@m" uk-grid uk-lightbox="animation: fade">
						{% for photo in trajet_gallery %}
							<div class="oc-gallery__card uk-position-relative">
								<a class="oc-gallery__item" href="{{ photo.url }}" data-caption="{{ photo.caption ?? photo.alt }}{% if photo.copyright %} — © {{ photo.copyright }}{% endif %}">
									<img src="{{ photo.thumb }}" alt="{{ photo.alt }}" loading="lazy">
								</a>
                {% if photo.achat and photo.achat != '' %}
                  <a class="uk-position-absolute gg-buy-picture" uk-icon="icon: cart" href="{{ photo.achat }}"></a>
                {% endif %}
								{% if photo.caption %}
                  <p class="oc-gallery__caption">{{ photo.caption }}</p>
                {% endif %}
							</div>
						{% endfor %}
					</div>
				</section>
			{% endif %}

		</div>
	</div>
</article>
