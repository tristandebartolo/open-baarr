{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}
<article{{attributes.addClass(classes)}}>
	<header class="oo-node-header-tiny">
		{% if label and not page %}
			{% if color %}
				{% set border_attribute = 'text-shadow: 20px 20px 49px ' ~ color  ~ ';'%}
				{% set title_attributes = title_attributes.setAttribute('style', border_attribute) %}
			{% endif %}
			<h3{{title_attributes.addClass('node__title')}}>
				<a href="{{ url }}" rel="bookmark">{{ label }}</a>
			</h3>
		{% endif %}
	</header>
	{% if content.field_chapo and content.field_chapo[0] %}
		<div{{content_attributes.addClass('node__content')}}>
			{% set chapo = content.field_chapo[0] and content.field_chapo[0]['#context'] ? content.field_chapo[0]['#context'].value : null %}
			{{ chapo|length > 100 ? chapo|slice(0, 100)|raw ~ '...' : chapo|raw }}
		</div>
	{% endif %}
</article>
