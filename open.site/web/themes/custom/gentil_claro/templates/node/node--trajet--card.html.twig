{#
/**
 * @file
 * Carte d'un trajet dans le listing /trajets.
 *
 * Variables injectées par opencar_display_preprocess_node() :
 * - trajet_activity : { type, label, color }
 * - trajet_started_at : date formatée ou null
 * - trajet_card_stats : mini-tuiles (distance, durée)
 * - trajet_map : { id } ou null — carte décorative en couverture (card-map.js)
 */
#}
{%
  set classes = [
    'node',
    'node-card',
    'node--type-' ~ node.bundle|clean_class,
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'oc-trajet-card',
  ]
%}
<article{{ attributes.addClass(classes).setAttribute('style', '--oc-activity: ' ~ trajet_activity.color) }} data-clk-oo="true">
	{% if trajet_map %}
		<div class="oc-trajet-card__media oc-trajet-card__map">
			<div class="oc-trajet-card__map-canvas" data-opencar-card-map="{{ trajet_map.id }}" role="img" aria-label="{{ 'Tracé du trajet'|t }}"></div>
		</div>
	{% elseif content.field_vignette|render %}
		<div class="oc-trajet-card__media">{{ content.field_vignette }}</div>
	{% endif %}
	<div class="oc-trajet-card__body">
		<header class="oc-trajet-card__header">
			<span class="oc-activity-badge oc-activity-badge--small" aria-hidden="true">
				<span uk-icon="icon: location; ratio: 0.7"></span>
			</span>
			<div>
				<h2{{ title_attributes.addClass('oc-trajet-card__title') }}>
					<a data-clk-oo-target="{{ url }}" href="{{ url }}" rel="bookmark">{{ label }}</a>
				</h2>
				<p class="oc-trajet-meta">
					{{ trajet_activity.label }}{% if trajet_started_at %} · {{ trajet_started_at }}{% endif %}
				</p>
			</div>
		</header>
		{% if trajet_card_stats %}
			<div class="oc-trajet-card__stats">
				{% for tile in trajet_card_stats %}
					<span class="oc-trajet-card__stat">
						<span uk-icon="icon: {{ tile.icon }}; ratio: 0.7" aria-hidden="true"></span>
						{{ tile.value }}
					</span>
				{% endfor %}
			</div>
		{% endif %}
		{% if content.field_chapo|render %}
			<div class="oc-trajet-card__chapo">{{ content.field_chapo }}</div>
		{% endif %}
	</div>
</article>
