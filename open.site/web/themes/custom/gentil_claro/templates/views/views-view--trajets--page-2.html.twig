{#
/**
 * @file
 * Vue trajets — bannière premium sur la page /trajets.
 *
 * Le display page_1 reçoit une bannière (titre h1 — aucun bloc titre n'est
 * rendu par le thème — + description éditable dans l'UI Views : header de la
 * vue, area text). Le display embed_front (page d'accueil) ne rend que la
 * grille de cartes.
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{ attributes.addClass(classes) }}>
	{{ title_prefix }}{{ title_suffix }}

	{% if display_id == 'page_2' %}
		<header class="oc-listing-hero">
			<div class="uk-container">
				<p class="oc-listing-hero__kicker">{{ 'Carnet de voyage'|t }}</p>
				<h1 class="oc-listing-hero__title">{{ 'Notes'|t }}</h1>
				{% if header %}
					<div class="oc-listing-hero__desc">{{ header }}</div>
				{% endif %}
			</div>
		</header>
	{% endif %}

	{% if exposed %}
		<div class="view-filters">{{ exposed }}</div>
	{% endif %}
	{{ attachment_before }}

  {% if rows %}
		<div class="uk-section uk-section-xsmall">
			<div class="uk-container">
				<div class="view-content">
          {{ rows }}
        </div>
			</div>
		</div>
	{% elseif empty %}
		<div class="uk-section uk-section-xsmall">
			<div class="uk-container">
				<div class="view-empty">{{ empty }}</div>
			</div>
		</div>
	{% endif %}

  {% if pager or attachment_after or more %}
    <div class="uk-section uk-section-xsmall">
      <div class="uk-container">
        	{{ pager }}
          {{ attachment_after }}
          {{ more }}
      </div>
    </div>
	{% endif %}

	{% if footer %}
		<footer class="view-footer">{{ footer }}</footer>
	{% endif %}
	{{ feed_icons }}
</div>
