{#
/**
 * @file
 * Vue trajets — bannière premium sur la page /trajets.
 *
 * Le display page_1 reçoit une bannière (titre h1 — aucun bloc titre n'est
 * rendu par le thème — + description éditable dans l'UI Views : header de la
 * vue, area text). Le display embed_front (page d'accueil) ne rend que la
 * grille de cartes.
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{ attributes.addClass(classes) }}>
	{{ title_prefix }}{{ title_suffix }}

	{% if display_id == 'page_1' %}
		<header class="oc-listing-hero">
			<div class="uk-container">
				<p class="oc-listing-hero__kicker">{{ 'Carnet de route'|t }}</p>
				<h1 class="oc-listing-hero__title">{{ 'Trajets'|t }}</h1>
				{% if header %}
					<div class="oc-listing-hero__desc">{{ header }}</div>
				{% endif %}
			</div>
		</header>
	{% endif %}

	{% if exposed %}
		<div class="view-filters">{{ exposed }}</div>
	{% endif %}
	{{ attachment_before }}

	{# Section 1 — Hero « Dernier voyage » (page 1 uniquement, injecté en preprocess). #}
	{% if trajets_hero %}
		<section class="oc-section oc-listing-featured" aria-labelledby="oc-listing-featured-label">
			<h2 id="oc-listing-featured-label" class="visually-hidden">{{ 'Dernier voyage'|t }}</h2>
			{{ trajets_hero }}
		</section>
	{% endif %}

	{# Section 2 — À la une : les 3 trajets suivants en cards. #}
	{% if trajets_cards %}
		<section class="oc-section" aria-labelledby="oc-listing-cards-label">
			<div class="uk-container">
				<h2 id="oc-listing-cards-label" class="oc-section-label">{{ 'À la une'|t }}</h2>
				<div class="oc-listing-cards">{{ trajets_cards }}</div>
			</div>
		</section>
	{% endif %}

  {% if rows %}
		{# Section 3 — Tous les trajets : le reste de la liste en tiny, paginé. #}
		<div class="uk-section uk-section-xsmall">
			<div class="uk-container">
				{% if trajets_hero or trajets_cards %}
					<h2 class="oc-section-label">{{ 'Tous les trajets'|t }}</h2>
				{% endif %}
				<div class="view-content">
          {{ rows }}
        </div>
			</div>
		</div>
	{% elseif empty %}
		<div class="uk-section uk-section-xsmall">
			<div class="uk-container">
				<div class="view-empty">{{ empty }}</div>
			</div>
		</div>
	{% endif %}

  {% if pager or attachment_after or more %}
    <div class="uk-section uk-section-xsmall">
      <div class="uk-container">
        	{{ pager }}
          {{ attachment_after }}
          {{ more }}
      </div>
    </div>
	{% endif %}

	{% if footer %}
		<footer class="view-footer">{{ footer }}</footer>
	{% endif %}
	{{ feed_icons }}
</div>
