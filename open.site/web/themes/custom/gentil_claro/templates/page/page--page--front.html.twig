{#
/**
 * @file
 * Page d'accueil premium.
 *
 * Sections dynamiques injectées par opencar_display_preprocess_page() :
 * - front_hero : { has_map, title, baseline, cta_url }
 * - front_trips : vue trajets, display embed_front (3 cartes)
 * - front_stats : tuiles de chiffres clés publics (partial trajet-stat-tile)
 * - front_articles : derniers articles en view mode card
 * - front_cacheability : render array portant les cache tags des sections
 *
 * Le contenu éditorial du node d'accueil (page.content) n'est volontairement
 * pas rendu : l'accueil est entièrement composé de sections dynamiques.
 */
#}
{# Menu #}
{% include directory ~ '/templates/partials/gntl-menu.html.twig' %}
<div class="gntl-main">
	<main id="contenu-principal">
		{{ front_cacheability }}
		{% if page.msg %}
			<div class="uk-container">{{ page.msg }}</div>
		{% endif %}

		{# Hero : carte du dernier trajet publié en fond, contenu par-dessus. #}
		<section class="oc-front-hero">
			{% if front_hero.has_map %}
				<div class="oc-front-hero__map" data-opencar-front-hero aria-hidden="true"></div>
			{% endif %}
			<div class="oc-front-hero__veil" aria-hidden="true"></div>
			<div class="oc-front-hero__content uk-container">
				<h1 class="oc-front-hero__title">{{ front_hero.title }}</h1>
				<p class="oc-front-hero__baseline">{{ front_hero.baseline }}</p>
				<a class="oc-btn oc-btn--primary" href="{{ front_hero.cta_url }}">
					{{ 'Voir les trajets'|t }}
					<span uk-icon="icon: arrow-right" aria-hidden="true"></span>
				</a>
			</div>
		</section>

		{# La route : timeline horizontale des derniers trajets. #}
		{% if front_road %}
			<section class="oc-front-section oc-road-section">
				<div class="uk-container">
					<header class="oc-front-section__header">
						<h2 class="oc-front-section__title">{{ 'La route'|t }}</h2>
						<a class="oc-front-section__more" href="/trajets">{{ 'Tous les trajets'|t }} <span uk-icon="icon: arrow-right; ratio: 0.8" aria-hidden="true"></span></a>
					</header>
				</div>
				{#
					Route sinueuse : chemin SVG en S calculé ici — les jalons sont sur
					les crêtes (carte au-dessus) et les creux (carte au-dessous).
					Géométrie : un point tous les `spacing` px, ondulation entre yTop
					et yBottom, segments en courbes de Bézier à tangentes horizontales.
				#}
				{% set spacing = 260 %}
				{% set margin = 150 %}
				{% set y_top = 170 %}
				{% set y_bottom = 310 %}
				{% set svg_height = 480 %}
				{% set svg_width = (margin * 2) + (spacing * (front_road|length - 1)) %}
				{% set path = '' %}
				{% for stop in front_road %}
					{% set x = margin + loop.index0 * spacing %}
					{% set y = loop.index0 is even ? y_top : y_bottom %}
					{% if loop.first %}
						{# La route entre dans le cadre par la gauche. #}
						{% set path = 'M -20 ' ~ y ~ ' L ' ~ x ~ ' ' ~ y %}
					{% else %}
						{% set prev_y = loop.index0 is even ? y_bottom : y_top %}
						{% set path = path ~ ' C ' ~ (x - spacing / 2) ~ ' ' ~ prev_y ~ ', ' ~ (x - spacing / 2) ~ ' ' ~ y ~ ', ' ~ x ~ ' ' ~ y %}
					{% endif %}
					{% if loop.last %}
						{# ... et ressort par la droite. #}
						{% set path = path ~ ' L ' ~ (svg_width + 20) ~ ' ' ~ y %}
					{% endif %}
				{% endfor %}
				<div class="oc-road" role="region" aria-label="{{ 'Derniers trajets sur la route'|t }}" tabindex="0">
					<div class="oc-road__track" style="width: {{ svg_width }}px; height: {{ svg_height }}px;">
						<svg class="oc-road__svg" viewBox="0 0 {{ svg_width }} {{ svg_height }}" width="{{ svg_width }}" height="{{ svg_height }}" aria-hidden="true">
							<path class="oc-road__asphalt" d="{{ path }}"/>
							<path class="oc-road__centerline" d="{{ path }}"/>
						</svg>
						<ul class="oc-road__stops" uk-scrollspy="target: > li; cls: uk-animation-slide-bottom-small; delay: 120">
							{% for stop in front_road %}
								{% set x = margin + loop.index0 * spacing %}
								{% set y = loop.index0 is even ? y_top : y_bottom %}
								<li class="oc-road__stop oc-road__stop--{{ loop.index0 is even ? 'up' : 'down' }}" style="--oc-x: {{ x }}px; --oc-y: {{ y }}px; --oc-activity: {{ stop.activity.color }}">
									<a class="oc-road__card" href="{{ stop.url }}">
										{% if stop.date %}
											<span class="oc-road__date">{{ stop.date }}</span>
										{% endif %}
										<span class="oc-road__title">{{ stop.title }}</span>
										<span class="oc-road__stats">
											{% if stop.distance %}
												<span><span uk-icon="icon: move; ratio: 0.6" aria-hidden="true"></span> {{ stop.distance }}</span>
											{% endif %}
											{% if stop.duration %}
												<span><span uk-icon="icon: clock; ratio: 0.6" aria-hidden="true"></span> {{ stop.duration }}</span>
											{% endif %}
										</span>
										<span class="oc-road__activity">{{ stop.activity.label }}</span>
									</a>
									<span class="oc-road__dot" aria-hidden="true"></span>
								</li>
							{% endfor %}
						</ul>
					</div>
				</div>
			</section>
		{% endif %}

		{# Derniers trajets. #}
		<section class="oc-front-section oc-front-trips">
			<div class="uk-container">
				<header class="oc-front-section__header">
					<h2 class="oc-front-section__title">{{ 'Derniers trajets'|t }}</h2>
					<a class="oc-front-section__more" href="/trajets">{{ 'Tous les trajets'|t }} <span uk-icon="icon: arrow-right; ratio: 0.8" aria-hidden="true"></span></a>
				</header>
				{{ front_trips }}
			</div>
		</section>

		{# Chiffres clés publics. #}
		{% if front_stats %}
			<section class="oc-front-section oc-front-stats">
				<div class="uk-container">
					<header class="oc-front-section__header">
						<h2 class="oc-front-section__title">{{ 'Chiffres clés'|t }}</h2>
					</header>
					<div class="oc-front-stats__grid">
						{% for tile in front_stats %}
							{% include '@gentil_claro/partials/trajet-stat-tile.html.twig' with { tile: tile } only %}
						{% endfor %}
					</div>
				</div>
			</section>
		{% endif %}

		{# Mur des baselines précédentes (la plus récente est dans le hero). #}
		{% if front_baselines %}
			<section class="oc-front-section oc-front-baselines">
				<div class="uk-container">
					<header class="oc-front-section__header">
						<h2 class="oc-front-section__title">{{ 'Notes'|t }}</h2>
					</header>
					<ul class="oc-baselines">
						{% for baseline in front_baselines %}
							<li class="oc-baselines__item">
								<span class="oc-baselines__mark" aria-hidden="true">“</span>
								<span class="oc-baselines__text">{{ baseline }}</span>
							</li>
						{% endfor %}
					</ul>
				</div>
			</section>
		{% endif %}

		{# Articles récents. #}
		{% if front_articles %}
			<section class="oc-front-section oc-front-articles">
				<div class="uk-container">
					<header class="oc-front-section__header">
						<h2 class="oc-front-section__title">{{ 'Articles récents'|t }}</h2>
					</header>
					<div class="oc-front-articles__grid">
						{{ front_articles }}
					</div>
				</div>
			</section>
		{% endif %}
	</main>
	{# Footer #}
	{% include directory ~ '/templates/partials/gntl-footer.html.twig' %}
</div>
