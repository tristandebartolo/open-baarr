{%
  set body_classes = [
    logged_in ? 'user-logged-in',
    not root_path ? 'brr-frontpage' : 'brr-' ~ root_path|clean_class,
    node_type ? 'page-' ~ node_type|clean_class,
    db_offline ? 'db-offline',
  ]
%}
<!DOCTYPE html>
<html{{html_attributes}}>
	<head>
		{# Anti-flash (FOUC) : applique la préférence dark/light stockée AVANT
		   le chargement des CSS. Doit rester inline et en tout premier. #}
		<script>
			(function () {
				try {
					var theme = localStorage.getItem('gentil_claro.theme.v1');
					if (theme === 'dark' || theme === 'light') {
						document.documentElement.setAttribute('data-theme', theme);
					}
				} catch (e) {}
			})();
		</script>
		<head-placeholder token="{{ placeholder_token|raw }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token|raw }}">
      <js-placeholder token="{{ placeholder_token|raw }}">
  </head>
  <body{{attributes.addClass(classes)}}>
    {#
      Keyboard navigation/accessibility link to main content section in
      page.html.twig.
    #}
    <a href="#contenu-principal" class="visually-hidden focusable">
      {{ 'Skip to main content'|t }}
    </a>
    {{ page_top }}
    {{ page }}
    {{ page_bottom }}
    <js-bottom-placeholder token="{{ placeholder_token|raw }}">
  </body>
</html>
